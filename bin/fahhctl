#!/usr/bin/env bash
set -euo pipefail

APP="fahh"
DATA_DIR="$HOME/.local/share/$APP"
SOUND_PATH="$DATA_DIR/fahh.mp3"

ZSHRC="$HOME/.zshrc"
BASHRC="$HOME/.bashrc"

ZSH_START="# >>> fahhctl zsh >>>"
ZSH_END="# <<< fahhctl zsh <<<"
BASH_START="# >>> fahhctl bash >>>"
BASH_END="# <<< fahhctl bash <<<"
PATH_START="# >>> fahhctl path >>>"
PATH_END="# <<< fahhctl path <<<"

remove_block() {
  local file="$1" start="$2" end="$3"
  [ -f "$file" ] || return 0
  perl -0777 -i -pe "s/\n?\Q$start\E.*?\Q$end\E\n?/\n/s" "$file" || true
}

ensure_path() {
  local file="$1"
  [ -f "$file" ] || touch "$file"
  if ! grep -qF "$PATH_START" "$file"; then
    cat >>"$file" <<EOF

$PATH_START
export PATH="\$HOME/.local/bin:\$PATH"
$PATH_END
EOF
  fi
}

enable_zsh() {
  [ -f "$ZSHRC" ] || touch "$ZSHRC"
  remove_block "$ZSHRC" "$ZSH_START" "$ZSH_END"
  cat >>"$ZSHRC" <<EOF

$ZSH_START
command_not_found_handler() {
  if command -v fahhctl >/dev/null 2>&1; then
    fahhctl play >/dev/null 2>&1 &
  fi
  print -u2 "zsh: command not found: \$1"
  return 127
}
$ZSH_END
EOF
}

enable_bash() {
  [ -f "$BASHRC" ] || touch "$BASHRC"
  remove_block "$BASHRC" "$BASH_START" "$BASH_END"
  cat >>"$BASHRC" <<EOF

$BASH_START
command_not_found_handle() {
  if command -v fahhctl >/dev/null 2>&1; then
    fahhctl play >/dev/null 2>&1 &
  fi
  echo "bash: \$1: command not found"
  return 127
}
$BASH_END
EOF
}

disable_all() {
  remove_block "$ZSHRC" "$ZSH_START" "$ZSH_END"
  remove_block "$BASHRC" "$BASH_START" "$BASH_END"
  # optional: remove PATH block too
  remove_block "$ZSHRC" "$PATH_START" "$PATH_END"
  remove_block "$BASHRC" "$PATH_START" "$PATH_END"
}

play() {
  [ -f "$SOUND_PATH" ] || exit 0

  if command -v mpv >/dev/null 2>&1; then
    mpv --no-video --really-quiet "$SOUND_PATH" >/dev/null 2>&1 &
  elif command -v ffplay >/dev/null 2>&1; then
    ffplay -nodisp -autoexit -loglevel quiet "$SOUND_PATH" >/dev/null 2>&1 &
  elif command -v mpg123 >/dev/null 2>&1; then
    mpg123 -q "$SOUND_PATH" >/dev/null 2>&1 &
  elif command -v paplay >/dev/null 2>&1; then
    paplay "$SOUND_PATH" >/dev/null 2>&1 &
  elif command -v aplay >/dev/null 2>&1; then
    aplay -q "$SOUND_PATH" >/dev/null 2>&1 &
  else
    printf "\a" >/dev/null 2>&1 || true
  fi
}

status() {
  echo "Sound: $SOUND_PATH -> $([ -f "$SOUND_PATH" ] && echo OK || echo MISSING)"
  echo "Hooks:"
  echo "  zsh:  $([ -f "$ZSHRC" ] && grep -qF "$ZSH_START" "$ZSHRC" && echo ENABLED || echo DISABLED)"
  echo "  bash: $([ -f "$BASHRC" ] && grep -qF "$BASH_START" "$BASHRC" && echo ENABLED || echo DISABLED)"
}

case "${1:-}" in
  enable)
    ensure_path "$ZSHRC"
    ensure_path "$BASHRC"
    enable_zsh
    enable_bash
    echo "Hooks enabled ✅"
    ;;
  disable)
    disable_all
    echo "Hooks disabled ✅"
    ;;
  play) play ;;
  status) status ;;
  *)
    cat <<EOF
Usage:
  fahhctl enable
  fahhctl disable
  fahhctl status
  fahhctl play
EOF
    exit 2
    ;;
esac