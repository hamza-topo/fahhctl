#!/usr/bin/env bash
set -euo pipefail

APP="fahh"
DATA_DIR="$HOME/.local/share/$APP"
BIN_DIR="$HOME/.local/bin"
SOUND_PATH="$HOME/.local/share/fahh/fahh.mp3"
ZSHRC="$HOME/.zshrc"
BASHRC="$HOME/.bashrc"

MARK_START="# >>> fahhctl >>>"
MARK_END="# <<< fahhctl <<<"

remove_block() {
  local file="$1"
  [ -f "$file" ] || return 0
  perl -0777 -i -pe "s/\n?\Q$MARK_START\E.*?\Q$MARK_END\E\n?/\n/s" "$file" || true
}

ensure_path_line() {
  local file="$1"
  [ -f "$file" ] || touch "$file"
  if ! grep -qF "$MARK_START" "$file"; then
    cat >> "$file" <<EOF

$MARK_START
# Ensure ~/.local/bin is in PATH (needed for fahhctl)
export PATH="\$HOME/.local/bin:\$PATH"
$MARK_END
EOF
  fi
}

install_hooks() {
  # zsh
  [ -f "$ZSHRC" ] || touch "$ZSHRC"
  remove_block "$ZSHRC"
  cat >> "$ZSHRC" <<'EOF'

# >>> fahhctl >>>
command_not_found_handler() {
  if command -v fahhctl >/dev/null 2>&1; then
    fahhctl play >/dev/null 2>&1 &
  fi
  print -u2 "zsh: command not found: $1"
  return 127
}
# <<< fahhctl <<<
EOF

  # bash
  [ -f "$BASHRC" ] || touch "$BASHRC"
  remove_block "$BASHRC"
  cat >> "$BASHRC" <<'EOF'

# >>> fahhctl >>>
command_not_found_handle() {
  if command -v fahhctl >/dev/null 2>&1; then
    fahhctl play >/dev/null 2>&1 &
  fi
  echo "bash: $1: command not found"
  return 127
}
# <<< fahhctl <<<
EOF
}

play() {
  [ -f "$SOUND_PATH" ] || exit 0

  if command -v mpv >/dev/null 2>&1; then
    mpv --no-video --really-quiet "$SOUND_PATH" >/dev/null 2>&1 &
  elif command -v ffplay >/dev/null 2>&1; then
    ffplay -nodisp -autoexit -loglevel quiet "$SOUND_PATH" >/dev/null 2>&1 &
  elif command -v mpg123 >/dev/null 2>&1; then
    mpg123 -q "$SOUND_PATH" >/dev/null 2>&1 &
  elif command -v paplay >/dev/null 2>&1; then
    paplay "$SOUND_PATH" >/dev/null 2>&1 &
  elif command -v aplay >/dev/null 2>&1; then
    aplay -q "$SOUND_PATH" >/dev/null 2>&1 &
  else
    printf "\a" >/dev/null 2>&1 || true
  fi
}

cmd_install() {
  local src="${1:-}"
  if [ -z "$src" ] || [ ! -f "$src" ]; then
    echo "Usage: fahhctl install /path/to/fahh.(mp3|wav)"
    exit 1
  fi

  mkdir -p "$DATA_DIR" "$BIN_DIR"
  cp -f "$src" "$SOUND_PATH"

  ensure_path_line "$ZSHRC"
  ensure_path_line "$BASHRC"
  install_hooks

  echo "Installed ✅"
  echo "Sound: $SOUND_PATH"
  echo "Reload: source ~/.zshrc (or open a new terminal)"
}

cmd_uninstall() {
  remove_block "$ZSHRC"
  remove_block "$BASHRC"
  rm -rf "$DATA_DIR" 2>/dev/null || true
  echo "Uninstalled ✅ (hooks removed, sound deleted)"
}

cmd_status() {
  echo "Sound: $SOUND_PATH -> $([ -f "$SOUND_PATH" ] && echo OK || echo MISSING)"
  echo "Players:"
  echo "  mpv:    $(command -v mpv >/dev/null 2>&1 && echo OK || echo NO)"
  echo "  ffplay: $(command -v ffplay >/dev/null 2>&1 && echo OK || echo NO)"
  echo "  mpg123: $(command -v mpg123 >/dev/null 2>&1 && echo OK || echo NO)"
  echo "  paplay: $(command -v paplay >/dev/null 2>&1 && echo OK || echo NO)"
  echo "  aplay:  $(command -v aplay >/dev/null 2>&1 && echo OK || echo NO)"
}

case "${1:-}" in
  install) shift; cmd_install "${1:-}" ;;
  uninstall) cmd_uninstall ;;
  play) play ;;
  status) cmd_status ;;
  *)
    cat <<EOF
Usage:
  fahhctl install /path/to/fahh.(mp3|wav)
  fahhctl status
  fahhctl play
  fahhctl uninstall
EOF
    ;;
esac
